# ===========================================
# Layer8 Production Environment Configuration
# ===========================================

# --- Core ---
NODE_ENV=production
PORT=3001

# --- Database (SQLite) ---
# Absolute path to SQLite database file. MUST use file: prefix.
DATABASE_URL=file:/opt/layer8/backend/prod.db

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Security ---
# Auto-generated during install. 64-character random string.
SESSION_SECRET=

# --- Frontend URL ---
# Must match the domain configured in nginx. Used for CORS.
FRONTEND_URL=https://your-domain.com

# --- Feature Flags (all disabled for Schedule-only deployment) ---
FEATURE_TEMPLATE_ADAPTER=false
FEATURE_EXECUTIVE_REPORT=false
FEATURE_DOCUMENT_PROCESSING=false

# --- Optional Services (disabled, for future use) ---
# SANITIZER_URL=http://localhost:8000
# GOTENBERG_URL=http://localhost:3000
# GHOSTWRITER_URL=
# GHOSTWRITER_API_TOKEN=
# GHOSTWRITER_REPORT_ID=
