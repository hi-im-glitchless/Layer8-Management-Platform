[Unit]
Description=Layer8 Backend
After=network.target redis-server.service
Requires=redis-server.service

[Service]
Type=simple
User=layer8
Group=layer8
WorkingDirectory=/opt/layer8/backend
ExecStart=/usr/bin/npx tsx src/index.ts
Restart=on-failure
RestartSec=5
EnvironmentFile=/opt/layer8/backend/.env
StandardOutput=journal
StandardError=journal
SyslogIdentifier=layer8

[Install]
WantedBy=multi-user.target
