// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  NORMAL
  PM
  MANAGER
  ADMIN
}

model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  passwordHash        String
  role                Role      @default(NORMAL)
  isActive            Boolean   @default(true)
  mustResetPassword   Boolean   @default(true)
  totpSecret          String?
  totpEnabled         Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  displayName         String?
  avatarUrl           String?
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  trustedDevices TrustedDevice[]
  auditLogs      AuditLog[]
  denyListTerms  DenyListTerm[]
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  deviceHash String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceHash])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  details      String   @default("{}")
  ipAddress    String
  previousHash String
  hash         String
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model DenyListTerm {
  id          String   @id @default(cuid())
  term        String
  description String?
  createdBy   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([term])
  @@index([isActive])
}

model LlmSettings {
  id                   String   @id @default("singleton")
  cliproxyBaseUrl      String   @default("http://localhost:8317")
  anthropicApiKey      String?
  defaultModel         String   @default("claude-sonnet-4-5-20250929")
  templateAdapterModel String   @default("claude-sonnet-4-5-20250929")
  executiveReportModel String   @default("claude-opus-4-6")
  fallbackEnabled      Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model TemplateMapping {
  id                    String   @id @default(cuid())
  templateType          String   // web|internal|mobile
  language              String   // en|pt-pt
  normalizedSectionText String   // lowercase, whitespace-collapsed section text
  gwField               String   // target GW field path (e.g. "client.short_name")
  markerType            String   // text|paragraph_rt|run_rt|table_row_loop|control_flow
  confidence            Float    @default(1.0) // last-seen confidence from mapping plan
  usageCount            Int      @default(1) // incremented on each duplicate upsert
  zone                  String   @default("unknown") // header|footer|body|table_cell|text_box|cover|unknown
  zoneRepetitionCount   Int      @default(1) // how many times this gwField appears in this zone
  correctionCount       Int      @default(0) // number of times user corrected this mapping
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([templateType, language, normalizedSectionText, gwField, zone])
  @@index([templateType, language])
  @@index([templateType, language, zone])
  @@index([usageCount])
}

model BlueprintPattern {
  id           String   @id @default(cuid())
  templateType String
  zone         String
  patternType  String   // loop|conditional|group
  markers      String   // JSON array: [{"gwField":"...","markerType":"..."},...]
  anchorStyle  String?  // paragraph style that anchors this pattern
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([templateType, zone, patternType, markers])
  @@index([templateType])
}

model StyleHint {
  id           String   @id @default(cuid())
  templateType String
  styleName    String
  zone         String   @default("body")
  mappedCount  Int      @default(0)
  skippedCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([templateType, styleName, zone])
  @@index([templateType])
}

/// Stores the full accepted mapping plan for a known template, keyed by structural hash.
/// When the same template is re-uploaded, the stored snapshot is returned directly
/// without any LLM analysis — giving 100% reproducible results.
model TemplateMappingSnapshot {
  id               String   @id @default(cuid())
  templateHash     String   // structural hash from document-structure service
  templateType     String   // web|internal|mobile
  language         String   // en|pt-pt
  mappingPlanJson  String   // full MappingPlan JSON
  entryCount       Int      @default(0)
  usageCount       Int      @default(1) // how many times this snapshot was replayed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([templateHash, templateType, language])
  @@index([templateType, language])
}
