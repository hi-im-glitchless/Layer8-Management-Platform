// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  NORMAL
  PM
  ADMIN
}

model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  passwordHash        String
  role                Role      @default(NORMAL)
  isActive            Boolean   @default(true)
  mustResetPassword   Boolean   @default(true)
  totpSecret          String?
  totpEnabled         Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  displayName         String?
  avatarUrl           String?
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  trustedDevices TrustedDevice[]
  auditLogs      AuditLog[]
  denyListTerms  DenyListTerm[]
  teamMembers    TeamMember[]
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  deviceHash String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceHash])
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  details      String   @default("{}")
  ipAddress    String
  previousHash String
  hash         String
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model DenyListTerm {
  id          String   @id @default(cuid())
  term        String
  description String?
  createdBy   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([term])
  @@index([isActive])
}

model LlmSettings {
  id                   String   @id @default("singleton")
  cliproxyBaseUrl      String   @default("http://localhost:8317")
  anthropicApiKey      String?
  defaultModel         String   @default("claude-sonnet-4-5-20250929")
  templateAdapterModel String   @default("claude-sonnet-4-5-20250929")
  executiveReportModel String   @default("claude-opus-4-6")
  fallbackEnabled      Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model TemplateMapping {
  id                    String   @id @default(cuid())
  templateType          String   // web|internal|mobile
  language              String   // en|pt-pt
  normalizedSectionText String   // lowercase, whitespace-collapsed section text
  gwField               String   // target GW field path (e.g. "client.short_name")
  markerType            String   // text|paragraph_rt|run_rt|table_row_loop|control_flow
  confidence            Float    @default(1.0) // last-seen confidence from mapping plan
  usageCount            Int      @default(1) // incremented on each duplicate upsert
  zone                  String   @default("unknown") // header|footer|body|table_cell|text_box|cover|unknown
  zoneRepetitionCount   Int      @default(1) // how many times this gwField appears in this zone
  correctionCount       Int      @default(0) // number of times user corrected this mapping
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([templateType, language, normalizedSectionText, gwField, zone])
  @@index([templateType, language])
  @@index([templateType, language, zone])
  @@index([usageCount])
}

model BlueprintPattern {
  id           String   @id @default(cuid())
  templateType String
  zone         String
  patternType  String   // loop|conditional|group
  markers      String   // JSON array: [{"gwField":"...","markerType":"..."},...]
  anchorStyle  String?  // paragraph style that anchors this pattern
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([templateType, zone, patternType, markers])
  @@index([templateType])
}

model StyleHint {
  id           String   @id @default(cuid())
  templateType String
  styleName    String
  zone         String   @default("body")
  mappedCount  Int      @default(0)
  skippedCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([templateType, styleName, zone])
  @@index([templateType])
}

/// Stores the full accepted mapping plan for a known template, keyed by structural hash.
/// When the same template is re-uploaded, the stored snapshot is returned directly
/// without any LLM analysis — giving 100% reproducible results.
model TemplateMappingSnapshot {
  id               String   @id @default(cuid())
  templateHash     String   // structural hash from document-structure service
  templateType     String   // web|internal|mobile
  language         String   // en|pt-pt
  mappingPlanJson  String   // full MappingPlan JSON
  entryCount       Int      @default(0)
  usageCount       Int      @default(1) // how many times this snapshot was replayed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([templateHash, templateType, language])
  @@index([templateType, language])
}

model TeamMember {
  id           String   @id @default(cuid())
  userId       String?  @unique
  displayOrder Int      @default(0)
  status       String   @default("active") // active, inactive, archived
  isBacklog    Boolean  @default(false)
  displayName  String?  // Used for backlog members (e.g. "Futuro 1")
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments Assignment[]
  absences    Absence[]

  @@index([status])
  @@index([displayOrder])
  @@index([isBacklog])
}

model Assignment {
  id                String   @id @default(cuid())
  teamMemberId      String
  projectName       String
  projectColor      String   // Hex color e.g. #FF5733
  status            String   @default("placeholder") // placeholder, needs-reqs, confirmed
  weekStart         DateTime // Monday of the week (ISO date)
  isLocked          Boolean  @default(false)
  splitProjectName   String?  // Second project name for split cells
  splitProjectColor  String?  // Second project color for split cells
  splitProjectStatus String?  // Status for split project half
  splitClientId      String?  // Optional client for split project
  splitTags          String   @default("[]") // JSON array of tags for split project
  createdBy          String?  // User ID who last modified
  clientId           String?  // Optional client association
  tags               String   @default("[]") // JSON array of tag strings e.g. ["Web", "Red Team"]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teamMember  TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  client      Client?    @relation("AssignmentClient", fields: [clientId], references: [id], onDelete: SetNull)
  splitClient Client?    @relation("AssignmentSplitClient", fields: [splitClientId], references: [id], onDelete: SetNull)

  @@unique([teamMemberId, weekStart])
  @@index([teamMemberId])
  @@index([weekStart])
  @@index([projectName])
  @@index([clientId])
  @@index([splitClientId])
}

model Absence {
  id           String   @id @default(cuid())
  teamMemberId String
  date         DateTime // Specific date (YYYY-MM-DD)
  type         String   // holiday, sick, vacation, other
  reason       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teamMember TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([teamMemberId, date])
  @@index([teamMemberId])
  @@index([date])
  @@index([type])
}

model Holiday {
  id          String   @id @default(cuid())
  name        String
  month       Int      // 1-12
  day         Int      // 1-31
  isRecurring Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, month, day])
  @@index([month, day])
}

model ProjectColor {
  id         String   @id @default(cuid())
  name       String   @unique
  color      String   // Hex color code
  usageCount Int      @default(1)
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([usageCount])
  @@index([lastUsedAt])
}

model Client {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   // Hex color code
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments      Assignment[] @relation("AssignmentClient")
  splitAssignments Assignment[] @relation("AssignmentSplitClient")
}
